# Copy to .env and fill these in if you want the router UI to launch local Modal workers.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
LLM_ROUTER_API_KEY=

# Optional comma-separated model suggestions shown in the UI.
MODAL_WORKER_MODEL_OPTIONS=Qwen/Qwen3.6-35B-A3B-FP8,Qwen/Qwen2.5-32B-Instruct,meta-llama/Llama-3.3-70B-Instruct,Qwen/Qwen2.5-Coder-32B-Instruct
